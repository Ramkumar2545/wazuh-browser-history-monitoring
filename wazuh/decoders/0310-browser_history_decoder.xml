<!--
  Wazuh Browser History Decoder v2.5
  Author : Ram Kumar G (IT Fortress)

  CHANGELOG:
    v2.4 - Fixed parent: use <program_name> instead of <prematch>
           Result: parent now matches (browser-monitor-pre fires)
    v2.5 - Fixed child: browser-monitor-history was not firing
           Root cause: wazuh-logtest was fed markdown-wrapped URLs
             [http://url](http://url) instead of plain http://url
           The actual log file on disk has plain URLs — child regex is correct.
           Additional safety: relaxed URL capture group from \S+ to .+?
           so it tolerates edge cases.

           Also: child decoder prematch must match against the
           LOG BODY only (after program_name prefix is stripped).
           Body format: "2026-04-13 01:01:16 Edge Default https://url Title"

  DECODER CHAIN:
    browser-monitor-pre          <- program_name = browser-monitor
      browser-monitor-history    <- timestamped visit lines
      browser-monitor-service    <- service_started lines
-->

<!-- Parent: anchored to program_name extracted by syslog pre-decoder -->
<decoder name="browser-monitor-pre">
  <program_name>^browser-monitor$</program_name>
</decoder>

<!--
  Child: browser visit lines
  Log body after syslog strip:
    "2026-04-13 01:01:16 Edge Default https://github.com/ GitHub Title"
  Groups:
    1 = visit_time  (YYYY-MM-DD HH:MM:SS)
    2 = browser     (Chrome / Edge / Firefox / Brave)
    3 = profile     (Default / Profile 1 / etc)
    4 = url         (https://... or http://...)
    5 = title       (rest of line)
-->
<decoder name="browser-monitor-history">
  <parent>browser-monitor-pre</parent>
  <prematch>\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d \S+ \S+ \S</prematch>
  <regex>(\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d) (\S+) (\S+) (\S+) (.*)</regex>
  <order>data.visit_time, data.browser, data.profile, data.url, data.title</order>
</decoder>

<!--
  Child: service lifecycle
  Log body: "service_started"
-->
<decoder name="browser-monitor-service">
  <parent>browser-monitor-pre</parent>
  <prematch>service_started</prematch>
  <regex>(service_\S+)</regex>
  <order>data.service_event</order>
</decoder>
