<!--
  Wazuh Browser History Decoder
  Author : Ram Kumar G (IT Fortress)
  Version: 2.8

  FIX (v2.8):
    1. program_name hyphen escaped: browser\-monitor
       (Wazuh uses POSIX regex for program_name — unescaped hyphen
        inside a character class means range; outside it still causes
        parse ambiguity. Escape it to be safe.)
    2. Added <use_own_name> to parent so Wazuh tracks it by name
       and the child <parent> reference resolves correctly.
    3. Child decoder has NO <prematch> — only <parent> + <regex>.
       Wazuh child decoders must NOT repeat prematch; they inherit
       the matched buffer from the parent and apply regex directly.

  Raw log format (post syslog-strip, what decoders see):
    2026-04-15 18:00:27 Safari blackweb Default https://www.facebook.com/ Facebook

  Fields:
    1. mon_browse_time     = 2026-04-15 18:00:27
    2. mon_browser_name    = Safari
    3. mon_username        = blackweb
    4. mon_browser_profile = Default
    5. mon_url             = https://www.facebook.com/
    6. mon_page_title      = Facebook - Log in or sign up
-->

<!-- Service lifecycle: service_started / service_stopped / no_browser_profiles_found -->
<decoder name="browser-monitor-service">
  <program_name>^browser\-monitor$</program_name>
  <prematch>^service_|^no_browser</prematch>
</decoder>

<!-- PARENT: match any visit line (starts with ISO timestamp) -->
<decoder name="browser-monitor-log">
  <program_name>^browser\-monitor$</program_name>
  <prematch>^\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d</prematch>
  <use_own_name>yes</use_own_name>
</decoder>

<!-- CHILD: extract all 6 fields from the visit line.
     No <prematch> here — child inherits parent's matched buffer.

     Regex captures:
       Group 1: timestamp   e.g. 2026-04-15 18:00:27
       Group 2: browser     e.g. Safari
       Group 3: username    e.g. blackweb
       Group 4: profile     e.g. Default
       Group 5: url         e.g. https://www.facebook.com/
       Group 6: title       e.g. Facebook - Log in or sign up  (or "No Title")

     URL group uses [^\s]+ (one-or-more non-whitespace) to handle
     any URL format including those wrapped in brackets.
-->
<decoder name="browser-monitor-log-fields">
  <parent>browser-monitor-log</parent>
  <regex type="pcre2">^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\s+(\S+)\s+(\S+)\s+(\S+)\s+(\S+)\s+(.+)$</regex>
  <order>mon_browse_time, mon_browser_name, mon_username, mon_browser_profile, mon_url, mon_page_title</order>
</decoder>
