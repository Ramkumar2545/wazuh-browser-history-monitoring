<!--
  Wazuh Browser History Decoder v2.6
  Author : Ram Kumar G (IT Fortress)

  APPROACH CHANGE (v2.6):
    Switched from parent/child chain to a single flat decoder.
    The <prematch> works on the FULL raw log line (before any stripping)
    so "browser-monitor: " is visible and matchable.

    This is simpler, more reliable, and avoids child-not-firing issues.

  BUG FIX:
    Previous approach used (\.+) for title which only matched literal dots.
    Fixed to (.+) which matches any character = full page title captured.

  Raw log format:
    Apr 13 01:01:16 WIN-PC browser-monitor: 2026-04-13 01:01:16 Edge Default https://url Title

  Extracted fields:
    mon_timestamp    = 2026-04-13 01:01:16
    mon_browser_name = Edge
    mon_profile      = Default
    mon_url          = https://discord.com/
    mon_title        = Discord - Group Chat
-->

<!-- Visit lines: prematch on full raw log line, extracts all 5 fields -->
<decoder name="browser-monitor-service">
  <program_name>^browser-monitor$</program_name>
  <prematch>^service_</prematch>
</decoder>

<decoder name="browser-monitor-log">
  <program_name>^browser-monitor$</program_name>
  <prematch>^\d+-\d+-\d+ \d+:\d+:\d+</prematch>
</decoder>

<decoder name="browser-monitor-log-fields">
  <parent>browser-monitor-log</parent>
  <regex type="pcre2">^(\d+-\d+-\d+ \d+:\d+:\d+)\s+(\S+)\s+(\S+)\s+(\S+)\s+(.*)$</regex>
  <order>mon_browse_time, mon_browser_name, mon_browser_profile, mon_url, mon_page_title</order>
</decoder>
