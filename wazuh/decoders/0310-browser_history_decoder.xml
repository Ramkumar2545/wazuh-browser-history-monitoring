<!--
  Wazuh Browser History Decoder v2.4
  Author : Ram Kumar G (IT Fortress)

  ROOT FIX (v2.4):
    Wazuh syslog pre-decoder strips the header:
      "Apr 13 01:01:16 WIN-PL08JLEAUN1 browser-monitor: "
    ...before passing to custom decoders.
    So the parent <prematch>browser-monitor: </prematch> NEVER matches
    because that prefix is already gone.

    Fix: use <program_name> in the PARENT decoder instead of <prematch>.
    <program_name> matches against the pre-decoded program_name field
    (extracted from syslog header), NOT the log body.
    Child decoders then receive only the body after "browser-monitor: ".

  DECODER CHAIN:
    browser-monitor-pre          <- matches program_name = browser-monitor
      browser-monitor-history    <- matches timestamped visit lines
      browser-monitor-service    <- matches service_started lines
-->

<!-- Parent: match by program_name (pre-decoded from syslog header) -->
<decoder name="browser-monitor-pre">
  <program_name>^browser-monitor$</program_name>
</decoder>

<!-- Child: browser visit lines
     Body received: "2026-04-13 01:01:16 Edge Default https://github.com/ GitHub"
-->
<decoder name="browser-monitor-history">
  <parent>browser-monitor-pre</parent>
  <prematch>\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d </prematch>
  <regex>(\d\d\d\d-\d\d-\d\d \d\d:\d\d:\d\d) (\S+) (\S+) (\S+) (.*)</regex>
  <order>data.visit_time, data.browser, data.profile, data.url, data.title</order>
</decoder>

<!-- Child: service lifecycle lines
     Body received: "service_started"
-->
<decoder name="browser-monitor-service">
  <parent>browser-monitor-pre</parent>
  <prematch>service_started</prematch>
  <regex>(service_\S+)</regex>
  <order>data.service_event</order>
</decoder>
